{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/project-pack-factory/benchmark-active-set.schema.json",
  "title": "Project Pack Active Benchmark Set",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_id",
    "pack_kind",
    "default_benchmark_id",
    "active_benchmarks"
  ],
  "properties": {
    "schema_version": {
      "const": "pack-benchmark-active-set/v1"
    },
    "pack_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "pack_kind": {
      "type": "string",
      "enum": [
        "template_pack",
        "build_pack"
      ]
    },
    "default_benchmark_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "active_benchmarks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "benchmark_id",
          "declaration_path",
          "objective",
          "required_for_readiness"
        ],
        "properties": {
          "benchmark_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "declaration_path": {
            "type": "string",
            "pattern": "^benchmarks/declarations/[^/]+\\.json$"
          },
          "objective": {
            "type": "string",
            "minLength": 1
          },
          "required_for_readiness": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
