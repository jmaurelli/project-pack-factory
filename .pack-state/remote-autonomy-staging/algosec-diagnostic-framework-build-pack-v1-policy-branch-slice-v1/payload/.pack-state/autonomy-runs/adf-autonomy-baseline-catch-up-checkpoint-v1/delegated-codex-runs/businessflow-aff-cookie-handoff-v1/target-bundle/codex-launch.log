+/usr/share/fa/php/SSOLogin.php (createFireFlowUserAndRedirect)
+--------------------------------------------------------------
+		$params = 	  '?action=add&userName='
+					. rawurlencode($username)
+					. '&authMethod=SSO'
+					. '&AFF_COOKIE='.rawurlencode(utils::getFireflowCookie());
+
+		// Send the request.
+		$affAddress = utils::GetFireFlowFullAddress();
+		$responseContent = utils::RequestHTTP($affAddress . $CreateUpdateExtAuthPrivUser_path . $params, true);
+...
+		$sid 					= $xmlRes->SID;
+		$sessionCookieName 		= $xmlRes->SessionCookieName;
+		$sessionCookieSecured 	= ($xmlRes->SessionCookieSecured == "1");
+        $bfCookie = $xmlRes->BFCookie;
+...
+		setcookie($sessionCookieName, $sid, NULL, "/", NULL, $sessionCookieSecured);
+...
+            $bfCookieName = $matches[1];
+            $bfCookieVal = $matches[2];
+
+            setcookie($bfCookieName, $bfCookieVal, NULL, "/BusinessFlow", NULL, $sessionCookieSecured);
+
+/usr/share/fa/php/SuiteLoginSessionValidation.php (redirectOrRespond)
+-------------------------------------------------------------------
+		if (!$authenticated) {
+			// Delete all existing cookies when in the login page and not logged in
+			header_remove("set-cookie");
+			$expired = time() - 1;
+			setcookie(PHP_COOKIE, "", $expired, "/", "", true, true);
+			setcookie(AFF_COOKIE, "", $expired, "/", "", true, true);
+			setcookie("JSESSIONID", "", $expired, "/BusinessFlow/", "", true, true);
+			setcookie("JSESSIONID", "", $expired, "/aff/", "", true, true);
+			setcookie("SEIKAN_SESSION", "", $expired, "/seikan/", "", true, true);
+		}
+
+/usr/share/fa/php/ci/application/controllers/Environment.php (getAFASessionInfo)
+---------------------------------------------------------------------------------
+	public function getAFASessionInfo()
+	{
+		if (empty($this->algosec->session)) {
+			$result = array('authenticated'=>false);
+		}
+		else
+		{
+			$result = array(
+				'faSession'=>$this->algosec->session->GetSessionId(),
+				'faDomain'=>$this->algosec->session->GetDomainId(),
+				'phpSession'=>$_COOKIE[PHP_COOKIE],
+				'isAdmin'=>$isAdmin,
+				'username'=>$this->algosec->session->GetUserName(),
+				'authenticated'=>true
+			);
+		}
