RewriteCond %{HTTP_HOST} ^ms-batch-application$
RewriteCond %{REMOTE_ADDR} ^127.0.0.1$
RewriteRule ^/(.*)$ http://127.0.0.1:8159/$1 [P]

# add trailing slash if missing
RewriteRule ^/ms-batch-application$ /ms-batch-application/ [R]

<Location /ms-batch-application/local>
ProxyPass !
</Location>
<Location /ms-batch-application>
    ProxyPass http://127.0.0.1:8159 timeout=18000 retry=0
    ProxyPassReverse http://127.0.0.1:8159
    SSLRequireSSL
    <IfModule mod_deflate.c>
        AddOutputFilterByType DEFLATE text/html text/plain text/xml text/javascript text/css application/json application/javascript
    </IfModule>
</Location>

