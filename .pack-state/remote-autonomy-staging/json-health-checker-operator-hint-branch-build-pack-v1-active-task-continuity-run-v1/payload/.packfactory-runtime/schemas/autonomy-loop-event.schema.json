{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/project-pack-factory/autonomy-loop-event.schema.json",
  "title": "Autonomy Loop Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "recorded_at",
    "step_index",
    "event_type",
    "active_task_id",
    "next_recommended_task_id",
    "decision_source",
    "memory_state",
    "commands_attempted",
    "outcome",
    "readiness_state_before",
    "readiness_state_after",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "const": "autonomy-loop-event/v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "step_index": {
      "type": "integer",
      "minimum": 1
    },
    "event_type": {
      "type": "string",
      "enum": [
        "run_started",
        "task_selected",
        "command_completed",
        "state_updated",
        "escalation_raised",
        "run_stopped",
        "run_completed"
      ]
    },
    "active_task_id": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        {
          "type": "null"
        }
      ]
    },
    "next_recommended_task_id": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        {
          "type": "null"
        }
      ]
    },
    "decision_source": {
      "type": "string",
      "enum": [
        "canonical_only",
        "canonical_plus_memory",
        "memory_only"
      ]
    },
    "memory_state": {
      "type": "string",
      "enum": [
        "not_used",
        "used_and_consistent",
        "used_and_stale",
        "used_and_incomplete"
      ]
    },
    "commands_attempted": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "outcome": {
      "type": "string",
      "minLength": 1
    },
    "readiness_state_before": {
      "type": "string",
      "minLength": 1
    },
    "readiness_state_after": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "stop_reason": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "evidence_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "baseline_snapshot": {
      "$ref": "#/$defs/canonical_snapshot"
    },
    "canonical_snapshot_after": {
      "$ref": "#/$defs/canonical_snapshot"
    }
  },
  "$defs": {
    "gate_statuses": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9_-]*$"
      },
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "eval_result_statuses": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9_-]*$"
      },
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "canonical_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active_task_id",
        "next_recommended_task_id",
        "readiness_state",
        "ready_for_deployment",
        "gate_statuses",
        "eval_result_statuses"
      ],
      "properties": {
        "active_task_id": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9_-]*$"
            },
            {
              "type": "null"
            }
          ]
        },
        "next_recommended_task_id": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9_-]*$"
            },
            {
              "type": "null"
            }
          ]
        },
        "readiness_state": {
          "type": "string",
          "minLength": 1
        },
        "ready_for_deployment": {
          "type": "boolean"
        },
        "gate_statuses": {
          "$ref": "#/$defs/gate_statuses"
        },
        "eval_result_statuses": {
          "$ref": "#/$defs/eval_result_statuses"
        }
      }
    }
  }
}
