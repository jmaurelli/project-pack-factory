{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/project-pack-factory/eval-latest-index.schema.json",
  "title": "Project Pack Latest Evaluation Index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_id",
    "pack_kind",
    "updated_at",
    "benchmark_results"
  ],
  "properties": {
    "schema_version": {
      "const": "pack-eval-index/v1"
    },
    "pack_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "pack_kind": {
      "type": "string",
      "enum": [
        "template_pack",
        "build_pack"
      ]
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "benchmark_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "benchmark_id",
          "status",
          "latest_run_id",
          "run_artifact_path",
          "summary_artifact_path"
        ],
        "properties": {
          "benchmark_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "in_progress",
              "not_run"
            ]
          },
          "latest_run_id": {
            "type": "string",
            "minLength": 1
          },
          "run_artifact_path": {
            "type": "string",
            "pattern": "^eval/history/.+\\.json$"
          },
          "summary_artifact_path": {
            "type": "string",
            "pattern": "^eval/(latest|history)/.+\\.json$"
          }
        }
      }
    }
  }
}
