{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/project-pack-factory/autonomy-run-summary.schema.json",
  "title": "Autonomy Run Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "pack_id",
    "started_at",
    "ended_at",
    "baseline_snapshot",
    "final_snapshot",
    "step_count",
    "resume_count",
    "completed_task_ids",
    "failed_command_count",
    "escalation_count",
    "stop_reason",
    "metrics",
    "operator_summary",
    "highest_risk_observation",
    "recommended_next_action",
    "autonomy_budget",
    "block_summary",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "const": "autonomy-run-summary/v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "pack_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "ended_at": {
      "type": "string",
      "format": "date-time"
    },
    "baseline_snapshot": {
      "$ref": "#/$defs/canonical_snapshot"
    },
    "final_snapshot": {
      "$ref": "#/$defs/canonical_snapshot"
    },
    "step_count": {
      "type": "integer",
      "minimum": 1
    },
    "resume_count": {
      "type": "integer",
      "minimum": 0
    },
    "completed_task_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9_-]*$"
      }
    },
    "failed_command_count": {
      "type": "integer",
      "minimum": 0
    },
    "escalation_count": {
      "type": "integer",
      "minimum": 0
    },
    "stop_reason": {
      "type": "string",
      "minLength": 1
    },
    "metrics": {
      "$ref": "#/$defs/metrics"
    },
    "operator_summary": {
      "type": "string",
      "minLength": 1
    },
    "highest_risk_observation": {
      "type": "string",
      "minLength": 1
    },
    "recommended_next_action": {
      "type": "string",
      "minLength": 1
    },
    "autonomy_budget": {
      "$ref": "#/$defs/autonomy_budget"
    },
    "block_summary": {
      "anyOf": [
        {
          "$ref": "#/$defs/block_summary"
        },
        {
          "type": "null"
        }
      ]
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "loop_events_path",
        "run_summary_path"
      ],
      "properties": {
        "loop_events_path": {
          "type": "string",
          "minLength": 1
        },
        "run_summary_path": {
          "type": "string",
          "minLength": 1
        },
        "feedback_memory_path": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "branch_selection_path": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "factory_validation_command": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        }
      }
    }
  },
  "$defs": {
    "autonomy_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "limits",
        "observed",
        "summary"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "within_budget",
            "budget_exceeded"
          ]
        },
        "limits": {
          "$ref": "#/$defs/autonomy_budget_values"
        },
        "observed": {
          "$ref": "#/$defs/autonomy_budget_values"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "autonomy_budget_values": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_step_count",
        "max_failed_command_count",
        "max_escalation_count",
        "max_elapsed_minutes"
      ],
      "properties": {
        "max_step_count": {
          "type": "integer",
          "minimum": 0
        },
        "max_failed_command_count": {
          "type": "integer",
          "minimum": 0
        },
        "max_escalation_count": {
          "type": "integer",
          "minimum": 0
        },
        "max_elapsed_minutes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "gate_statuses": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9_-]*$"
      },
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "eval_result_statuses": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9_-]*$"
      },
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "canonical_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active_task_id",
        "next_recommended_task_id",
        "readiness_state",
        "ready_for_deployment",
        "gate_statuses",
        "eval_result_statuses"
      ],
      "properties": {
        "active_task_id": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9_-]*$"
            },
            {
              "type": "null"
            }
          ]
        },
        "next_recommended_task_id": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9_-]*$"
            },
            {
              "type": "null"
            }
          ]
        },
        "readiness_state": {
          "type": "string",
          "minLength": 1
        },
        "ready_for_deployment": {
          "type": "boolean"
        },
        "gate_statuses": {
          "$ref": "#/$defs/gate_statuses"
        },
        "eval_result_statuses": {
          "$ref": "#/$defs/eval_result_statuses"
        }
      }
    },
    "nullable_rate": {
      "anyOf": [
        {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "nullable_iteration": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "canonical_state_integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "command",
        "valid",
        "error_count"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "not_run"
          ]
        },
        "command": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "valid": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "error_count": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "block_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "reason",
        "summary",
        "blocking_artifact_kind",
        "blocking_artifact_path",
        "recommended_recovery_action"
      ],
      "properties": {
        "status": {
          "const": "blocked"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "blocking_artifact_kind": {
          "type": "string",
          "enum": [
            "work_state",
            "readiness",
            "loop_events",
            "factory_validation",
            "runtime_evidence_export",
            "remote_execution"
          ]
        },
        "blocking_artifact_path": {
          "type": "string",
          "minLength": 1
        },
        "recommended_recovery_action": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_completion_rate",
        "iterations_to_first_evidence",
        "iterations_to_readiness_change",
        "readiness_change_summary",
        "validation_evidence_gain",
        "benchmark_evidence_gain",
        "canonical_state_integrity"
      ],
      "properties": {
        "task_completion_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "iterations_to_first_evidence": {
          "$ref": "#/$defs/nullable_iteration"
        },
        "iterations_to_readiness_change": {
          "$ref": "#/$defs/nullable_iteration"
        },
        "readiness_change_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "state_advanced",
            "deployability_changed",
            "gates_advanced_count"
          ],
          "properties": {
            "state_advanced": {
              "type": "boolean"
            },
            "deployability_changed": {
              "type": "boolean"
            },
            "gates_advanced_count": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "validation_evidence_gain": {
          "type": "boolean"
        },
        "benchmark_evidence_gain": {
          "type": "boolean"
        },
        "canonical_state_integrity": {
          "$ref": "#/$defs/canonical_state_integrity"
        },
        "resume_correctness": {
          "$ref": "#/$defs/nullable_rate"
        },
        "stale_memory_rate": {
          "$ref": "#/$defs/nullable_rate"
        },
        "consistent_memory_use_rate": {
          "$ref": "#/$defs/nullable_rate"
        }
      }
    }
  }
}
