{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/project-pack-factory/work-state.schema.json",
  "title": "Project Pack Work State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_id",
    "objective_id",
    "autonomy_state",
    "active_task_id",
    "next_recommended_task_id",
    "pending_task_ids",
    "blocked_task_ids",
    "completed_task_ids",
    "last_outcome",
    "last_outcome_at",
    "last_validation_results",
    "last_agent_action",
    "resume_instructions",
    "stop_conditions",
    "escalation_state"
  ],
  "properties": {
    "schema_version": {
      "const": "work-state/v1"
    },
    "pack_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "objective_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "autonomy_state": {
      "type": "string",
      "enum": [
        "idle",
        "actively_building",
        "blocked",
        "awaiting_operator",
        "ready_for_review",
        "ready_for_deploy",
        "completed"
      ]
    },
    "active_task_id": {
      "$ref": "#/$defs/nullable_task_id"
    },
    "next_recommended_task_id": {
      "$ref": "#/$defs/nullable_task_id"
    },
    "pending_task_ids": {
      "$ref": "#/$defs/task_id_array"
    },
    "blocked_task_ids": {
      "$ref": "#/$defs/task_id_array"
    },
    "completed_task_ids": {
      "$ref": "#/$defs/task_id_array"
    },
    "last_outcome": {
      "type": "string",
      "enum": [
        "task_completed",
        "validation_failed",
        "blocked",
        "escalated",
        "stopped"
      ]
    },
    "last_outcome_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_validation_results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validation_result"
      }
    },
    "last_agent_action": {
      "type": "string",
      "minLength": 1
    },
    "resume_instructions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "branch_selection_hints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/branch_selection_hint"
      }
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "escalation_state": {
      "type": "string",
      "enum": [
        "none",
        "pending",
        "raised",
        "resolved"
      ]
    }
  },
  "$defs": {
    "nullable_task_id": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        {
          "type": "null"
        }
      ]
    },
    "task_id_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9_-]*$"
      }
    },
    "branch_selection_hint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hint_id",
        "summary",
        "preferred_task_ids"
      ],
      "properties": {
        "hint_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "preferred_task_ids": {
          "$ref": "#/$defs/task_id_array"
        }
      }
    },
    "validation_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validation_id",
        "status",
        "summary",
        "evidence_paths",
        "recorded_at"
      ],
      "properties": {
        "validation_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "status": {
          "type": "string",
          "enum": [
            "not_run",
            "in_progress",
            "pass",
            "fail"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "evidence_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "recorded_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    }
  }
}
