{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/project-pack-factory/external-runtime-evidence-bundle.schema.json",
  "title": "External Runtime Evidence Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "export_id",
    "generated_at",
    "pack_id",
    "pack_kind",
    "run_id",
    "exported_by",
    "bundle_root",
    "source_runtime_roots",
    "authority_class",
    "control_plane_mutations",
    "artifact_manifest",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "const": "external-runtime-evidence-bundle/v1"
    },
    "export_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "pack_id": {
      "type": "string",
      "minLength": 1
    },
    "pack_kind": {
      "type": "string",
      "const": "build_pack"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "exported_by": {
      "type": "string",
      "minLength": 1
    },
    "bundle_root": {
      "type": "string",
      "minLength": 1
    },
    "source_runtime_roots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "authority_class": {
      "type": "string",
      "const": "supplementary_runtime_evidence"
    },
    "control_plane_mutations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "readiness_updated",
        "work_state_updated",
        "eval_latest_updated",
        "deployment_updated",
        "registry_updated",
        "release_artifacts_updated"
      ],
      "properties": {
        "readiness_updated": {
          "type": "boolean",
          "const": false
        },
        "work_state_updated": {
          "type": "boolean",
          "const": false
        },
        "eval_latest_updated": {
          "type": "boolean",
          "const": false
        },
        "deployment_updated": {
          "type": "boolean",
          "const": false
        },
        "registry_updated": {
          "type": "boolean",
          "const": false
        },
        "release_artifacts_updated": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "artifact_manifest": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "bundle_path",
          "source_pack_path",
          "sha256",
          "media_type",
          "required"
        ],
        "properties": {
          "bundle_path": {
            "type": "string",
            "minLength": 1
          },
          "source_pack_path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "media_type": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stop_reason",
        "started_at",
        "ended_at",
        "resume_count",
        "escalation_count",
        "task_completion_rate",
        "readiness_state_in_selected_run",
        "ready_for_deployment_in_selected_run"
      ],
      "properties": {
        "stop_reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "started_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "ended_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "resume_count": {
          "type": [
            "integer",
            "null"
          ]
        },
        "escalation_count": {
          "type": [
            "integer",
            "null"
          ]
        },
        "task_completion_rate": {
          "type": [
            "number",
            "null"
          ]
        },
        "readiness_state_in_selected_run": {
          "type": [
            "string",
            "null"
          ]
        },
        "ready_for_deployment_in_selected_run": {
          "type": [
            "boolean",
            "null"
          ]
        }
      }
    }
  }
}
