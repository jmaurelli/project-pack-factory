{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/project-pack-factory/deployment-pipeline-request.schema.json",
  "title": "Deployment Pipeline Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "build_pack_id",
    "target_environment",
    "release_id",
    "cloud_adapter_id",
    "invoked_by",
    "commit_promotion_on_success",
    "validation_command_ref",
    "benchmark_source",
    "verification_commands",
    "secret_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "deployment-pipeline-request/v1"
    },
    "build_pack_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "target_environment": {
      "type": "string",
      "enum": [
        "testing",
        "staging",
        "production"
      ]
    },
    "release_id": {
      "type": "string",
      "minLength": 1
    },
    "cloud_adapter_id": {
      "type": "string",
      "minLength": 1
    },
    "invoked_by": {
      "type": "string",
      "minLength": 1
    },
    "commit_promotion_on_success": {
      "type": "boolean"
    },
    "validation_command_ref": {
      "type": "string",
      "const": "pack.json.entrypoints.validation_command"
    },
    "benchmark_source": {
      "type": "string",
      "const": "status/readiness.json.required_gates"
    },
    "verification_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "secret_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
