{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/project-pack-factory/template-creation-report.schema.json",
  "title": "Project Pack Factory Template Creation Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "creation_id",
    "status",
    "template_pack_id",
    "created_at",
    "created_by",
    "planning_summary",
    "scaffold_strategy",
    "artifact_paths",
    "factory_mutations",
    "next_recommended_actions"
  ],
  "properties": {
    "schema_version": {
      "const": "template-creation-report/v1"
    },
    "creation_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "created",
        "reconciled",
        "failed"
      ]
    },
    "template_pack_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "planning_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_goal",
        "capability_family",
        "delivery_shape",
        "reuse_active_template",
        "new_template_rationale",
        "initial_benchmark_intent",
        "expected_build_pack_variants",
        "first_materialization_purpose"
      ],
      "properties": {
        "project_goal": {
          "type": "string",
          "minLength": 1
        },
        "capability_family": {
          "type": "string",
          "minLength": 1
        },
        "delivery_shape": {
          "type": "string",
          "enum": [
            "script",
            "component",
            "application",
            "library",
            "other"
          ]
        },
        "reuse_active_template": {
          "type": "boolean"
        },
        "new_template_rationale": {
          "type": "string"
        },
        "initial_benchmark_intent": {
          "type": "string",
          "minLength": 1
        },
        "expected_build_pack_variants": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "first_materialization_purpose": {
          "type": "string",
          "minLength": 1
        },
        "personality_template_selection": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "personality_template_id",
            "selection_reason",
            "apply_to_derived_build_packs_by_default"
          ],
          "properties": {
            "personality_template_id": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9_-]*$"
            },
            "selection_reason": {
              "type": "string",
              "minLength": 1
            },
            "apply_to_derived_build_packs_by_default": {
              "type": "boolean"
            }
          }
        },
        "role_domain_template_selection": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "role_domain_template_id",
            "selection_reason",
            "apply_to_derived_build_packs_by_default"
          ],
          "properties": {
            "role_domain_template_id": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9_-]*$"
            },
            "selection_reason": {
              "type": "string",
              "minLength": 1
            },
            "apply_to_derived_build_packs_by_default": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "resolved_personality_template": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "template_id",
        "display_name",
        "summary",
        "selection_origin",
        "selection_reason",
        "catalog_path",
        "apply_to_derived_build_packs_by_default"
      ],
      "properties": {
        "template_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "selection_origin": {
          "type": "string",
          "enum": [
            "template_selected",
            "materialization_inherited_default",
            "materialization_selected"
          ]
        },
        "selection_reason": {
          "type": "string",
          "minLength": 1
        },
        "catalog_path": {
          "type": "string",
          "const": "docs/specs/project-pack-factory/agent-personality-template-catalog.json"
        },
        "apply_to_derived_build_packs_by_default": {
          "type": "boolean"
        }
      }
    },
    "resolved_role_domain_template": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "template_id",
        "display_name",
        "summary",
        "selection_origin",
        "selection_reason",
        "catalog_path",
        "apply_to_derived_build_packs_by_default"
      ],
      "properties": {
        "template_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "selection_origin": {
          "type": "string",
          "enum": [
            "template_selected",
            "materialization_inherited_default",
            "materialization_selected"
          ]
        },
        "selection_reason": {
          "type": "string",
          "minLength": 1
        },
        "catalog_path": {
          "type": "string",
          "const": "docs/specs/project-pack-factory/agent-role-domain-template-catalog.json"
        },
        "apply_to_derived_build_packs_by_default": {
          "type": "boolean"
        }
      }
    },
    "scaffold_strategy": {
      "type": "string",
      "enum": [
        "minimal_python_text_pack"
      ]
    },
    "artifact_paths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "template_root",
        "pack_manifest",
        "lifecycle_file",
        "readiness_file",
        "creation_report"
      ],
      "properties": {
        "template_root": {
          "type": "string",
          "pattern": "^templates/.+$"
        },
        "pack_manifest": {
          "type": "string",
          "pattern": "^templates/.+/pack\\.json$"
        },
        "lifecycle_file": {
          "type": "string",
          "pattern": "^templates/.+/status/lifecycle\\.json$"
        },
        "readiness_file": {
          "type": "string",
          "pattern": "^templates/.+/status/readiness\\.json$"
        },
        "creation_report": {
          "type": "string",
          "pattern": "^templates/.+/eval/history/.+/template-creation-report\\.json$"
        }
      }
    },
    "factory_mutations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registry_updated",
        "operation_log_updated",
        "post_write_factory_validation"
      ],
      "properties": {
        "registry_updated": {
          "type": "boolean"
        },
        "operation_log_updated": {
          "type": "boolean"
        },
        "post_write_factory_validation": {
          "type": "string",
          "enum": [
            "pass",
            "fail"
          ]
        }
      }
    },
    "next_recommended_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
