{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/project-pack-factory/template-lineage-memory-pointer.schema.json",
  "title": "Template Lineage Memory Pointer",
  "description": "Pointer to the currently selected template-lineage memory artifact.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "updated_at",
    "template_id",
    "selected_memory_id",
    "selected_generated_at",
    "selected_memory_path",
    "selected_memory_sha256",
    "source_kind",
    "source_tool"
  ],
  "properties": {
    "schema_version": {
      "const": "template-lineage-memory-pointer/v1"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "template_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "selected_memory_id": {
      "type": "string",
      "pattern": "^template-lineage-memory-[a-z0-9][a-z0-9_-]*-[0-9]{8}t[0-9]{6}z$"
    },
    "selected_generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "selected_memory_path": {
      "type": "string",
      "pattern": "^\\.pack-state/template-lineage-memory/template-lineage-memory-[a-z0-9][a-z0-9_-]*-[0-9]{8}t[0-9]{6}z\\.json$"
    },
    "selected_memory_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "source_kind": {
      "type": "string",
      "const": "template_lineage_memory_refresh"
    },
    "source_tool": {
      "type": "string",
      "const": "tools/refresh_template_lineage_memory.py"
    }
  }
}
