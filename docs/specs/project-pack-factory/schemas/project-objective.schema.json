{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/project-pack-factory/project-objective.schema.json",
  "title": "Project Pack Objective",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_id",
    "source_template_id",
    "materialization_id",
    "generated_at",
    "objective_id",
    "objective_summary",
    "problem_statement",
    "intended_inputs",
    "intended_outputs",
    "success_criteria",
    "metrics",
    "non_goals",
    "completion_definition",
    "promotion_readiness_requirements"
  ],
  "properties": {
    "schema_version": {
      "const": "project-objective/v1"
    },
    "pack_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "source_template_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "materialization_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "objective_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "objective_summary": {
      "type": "string",
      "minLength": 1
    },
    "problem_statement": {
      "type": "string",
      "minLength": 1
    },
    "intended_inputs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "intended_outputs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "success_criteria": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/metric"
      }
    },
    "non_goals": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "completion_definition": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "promotion_readiness_requirements": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "autonomy_rehearsal_requirement": {
      "$ref": "#/$defs/autonomy_rehearsal_requirement"
    },
    "autonomy_quality_requirement": {
      "$ref": "#/$defs/autonomy_quality_requirement"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric_id",
        "summary",
        "target",
        "evidence_hint"
      ],
      "properties": {
        "metric_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_hint": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "autonomy_rehearsal_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_for_promotion",
        "workflow_id",
        "summary"
      ],
      "properties": {
        "required_for_promotion": {
          "type": "boolean"
        },
        "workflow_id": {
          "type": "string",
          "enum": [
            "multi_hop_autonomy_rehearsal"
          ]
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "autonomy_quality_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_for_promotion",
        "summary"
      ],
      "properties": {
        "required_for_promotion": {
          "type": "boolean"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "min_overall_rating": {
          "type": "string",
          "enum": [
            "good",
            "strong"
          ]
        },
        "min_overall_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "minimum_dimension_scores": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "required_for_promotion": {
                "const": true
              }
            }
          },
          "then": {
            "anyOf": [
              {
                "required": [
                  "min_overall_rating"
                ]
              },
              {
                "required": [
                  "min_overall_score"
                ]
              },
              {
                "required": [
                  "minimum_dimension_scores"
                ]
              }
            ]
          }
        }
      ]
    }
  }
}
