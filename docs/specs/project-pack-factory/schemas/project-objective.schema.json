{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/project-pack-factory/project-objective.schema.json",
  "title": "Project Pack Objective",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_id",
    "source_template_id",
    "materialization_id",
    "generated_at",
    "objective_id",
    "objective_summary",
    "problem_statement",
    "intended_inputs",
    "intended_outputs",
    "success_criteria",
    "metrics",
    "non_goals",
    "completion_definition",
    "promotion_readiness_requirements"
  ],
  "properties": {
    "schema_version": {
      "const": "project-objective/v1"
    },
    "pack_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "source_template_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "materialization_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "objective_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "objective_summary": {
      "type": "string",
      "minLength": 1
    },
    "problem_statement": {
      "type": "string",
      "minLength": 1
    },
    "intended_inputs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "intended_outputs": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "success_criteria": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/metric"
      }
    },
    "non_goals": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "completion_definition": {
      "$ref": "#/$defs/non_empty_string_array"
    },
    "promotion_readiness_requirements": {
      "$ref": "#/$defs/non_empty_string_array"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric_id",
        "summary",
        "target",
        "evidence_hint"
      ],
      "properties": {
        "metric_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_hint": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    }
  }
}
