{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/project-pack-factory/pack.schema.json",
  "title": "Project Pack Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_id",
    "pack_kind",
    "display_name",
    "owning_team",
    "runtime",
    "bootstrap_read_order",
    "post_bootstrap_read_order",
    "entrypoints",
    "directory_contract",
    "identity_source",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "const": "pack-manifest/v2"
    },
    "pack_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "pack_kind": {
      "type": "string",
      "enum": [
        "template_pack",
        "build_pack"
      ]
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "owning_team": {
      "type": "string",
      "minLength": 1
    },
    "runtime": {
      "type": "string",
      "enum": [
        "python",
        "typescript",
        "mixed"
      ]
    },
    "bootstrap_read_order": {
      "type": "array",
      "minItems": 3,
      "prefixItems": [
        {
          "const": "AGENTS.md"
        },
        {
          "const": "project-context.md"
        },
        {
          "const": "pack.json"
        }
      ],
      "items": false
    },
    "post_bootstrap_read_order": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "entrypoints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cli_command",
        "validation_command",
        "benchmark_command"
      ],
      "properties": {
        "cli_command": {
          "type": "string",
          "minLength": 1
        },
        "validation_command": {
          "type": "string",
          "minLength": 1
        },
        "benchmark_command": {
          "type": "string",
          "minLength": 1
        },
        "export_runtime_evidence_command": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "directory_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "docs_dir",
        "prompts_dir",
        "contracts_dir",
        "source_dir",
        "tests_dir",
        "benchmarks_dir",
        "benchmark_active_set_file",
        "eval_dir",
        "eval_latest_index_file",
        "eval_history_dir",
        "status_dir",
        "lifecycle_file",
        "readiness_file",
        "retirement_file",
        "deployment_file",
        "lineage_dir",
        "lineage_file",
        "dist_dir",
        "candidate_release_dir",
        "immutable_release_dir",
        "template_export_dir",
        "local_state_dir"
      ],
      "properties": {
        "docs_dir": {
          "type": "string",
          "const": "docs"
        },
        "prompts_dir": {
          "type": "string",
          "const": "prompts"
        },
        "contracts_dir": {
          "type": "string",
          "const": "contracts"
        },
        "project_objective_file": {
          "anyOf": [
            {
              "type": "string",
              "const": "contracts/project-objective.json"
            },
            {
              "type": "null"
            }
          ]
        },
        "source_dir": {
          "type": "string",
          "const": "src"
        },
        "tests_dir": {
          "type": "string",
          "const": "tests"
        },
        "tasks_dir": {
          "anyOf": [
            {
              "type": "string",
              "const": "tasks"
            },
            {
              "type": "null"
            }
          ]
        },
        "task_backlog_file": {
          "anyOf": [
            {
              "type": "string",
              "const": "tasks/active-backlog.json"
            },
            {
              "type": "null"
            }
          ]
        },
        "benchmarks_dir": {
          "type": "string",
          "const": "benchmarks"
        },
        "benchmark_active_set_file": {
          "type": "string",
          "const": "benchmarks/active-set.json"
        },
        "eval_dir": {
          "type": "string",
          "const": "eval"
        },
        "eval_latest_index_file": {
          "type": "string",
          "const": "eval/latest/index.json"
        },
        "eval_history_dir": {
          "type": "string",
          "const": "eval/history"
        },
        "status_dir": {
          "type": "string",
          "const": "status"
        },
        "lifecycle_file": {
          "type": "string",
          "const": "status/lifecycle.json"
        },
        "readiness_file": {
          "type": "string",
          "const": "status/readiness.json"
        },
        "retirement_file": {
          "type": "string",
          "const": "status/retirement.json"
        },
        "deployment_file": {
          "type": "string",
          "const": "status/deployment.json"
        },
        "work_state_file": {
          "anyOf": [
            {
              "type": "string",
              "const": "status/work-state.json"
            },
            {
              "type": "null"
            }
          ]
        },
        "lineage_dir": {
          "anyOf": [
            {
              "type": "string",
              "const": "lineage"
            },
            {
              "type": "null"
            }
          ]
        },
        "lineage_file": {
          "anyOf": [
            {
              "type": "string",
              "const": "lineage/source-template.json"
            },
            {
              "type": "null"
            }
          ]
        },
        "dist_dir": {
          "type": "string",
          "const": "dist"
        },
        "candidate_release_dir": {
          "anyOf": [
            {
              "type": "string",
              "const": "dist/candidates"
            },
            {
              "type": "null"
            }
          ]
        },
        "immutable_release_dir": {
          "anyOf": [
            {
              "type": "string",
              "const": "dist/releases"
            },
            {
              "type": "null"
            }
          ]
        },
        "runtime_evidence_export_dir": {
          "anyOf": [
            {
              "type": "string",
              "const": "dist/exports/runtime-evidence"
            },
            {
              "type": "null"
            }
          ]
        },
        "template_export_dir": {
          "anyOf": [
            {
              "type": "string",
              "const": "dist/exports"
            },
            {
              "type": "null"
            }
          ]
        },
        "local_state_dir": {
          "type": "string",
          "const": ".pack-state"
        },
        "portable_runtime_tools_dir": {
          "anyOf": [
            {
              "type": "string",
              "const": ".packfactory-runtime/tools"
            },
            {
              "type": "null"
            }
          ]
        },
        "portable_runtime_schemas_dir": {
          "anyOf": [
            {
              "type": "string",
              "const": ".packfactory-runtime/schemas"
            },
            {
              "type": "null"
            }
          ]
        },
        "portable_runtime_helper_manifest": {
          "anyOf": [
            {
              "type": "string",
              "const": ".packfactory-runtime/manifest.json"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "identity_source": {
      "type": "string",
      "const": "pack.json"
    },
    "agent_native_project_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "display_name",
        "summary",
        "selection_origin",
        "selection_reason",
        "activation_state",
        "apply_to_derived_build_packs_by_default",
        "work_management_model"
      ],
      "properties": {
        "profile_id": {
          "const": "packfactory_tracker_backed_agent_native"
        },
        "display_name": {
          "const": "PackFactory Tracker-Backed Agent-Native"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "selection_origin": {
          "type": "string",
          "enum": [
            "template_selected",
            "materialization_inherited_default",
            "materialization_forced_enabled"
          ]
        },
        "selection_reason": {
          "type": "string",
          "minLength": 1
        },
        "activation_state": {
          "type": "string",
          "enum": [
            "template_declared",
            "build_pack_active"
          ]
        },
        "apply_to_derived_build_packs_by_default": {
          "type": "boolean"
        },
        "work_management_model": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "canonical_tracker_mode",
            "planner_mode"
          ],
          "properties": {
            "canonical_tracker_mode": {
              "const": "objective_backlog_work_state"
            },
            "planner_mode": {
              "const": "tracker_backed_advisory_planning"
            }
          }
        }
      }
    },
    "personality_template": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "template_id",
        "display_name",
        "summary",
        "selection_origin",
        "selection_reason",
        "catalog_path",
        "apply_to_derived_build_packs_by_default"
      ],
      "properties": {
        "template_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "selection_origin": {
          "type": "string",
          "enum": [
            "template_selected",
            "materialization_inherited_default",
            "materialization_selected"
          ]
        },
        "selection_reason": {
          "type": "string",
          "minLength": 1
        },
        "catalog_path": {
          "type": "string",
          "const": "docs/specs/project-pack-factory/agent-personality-template-catalog.json"
        },
        "apply_to_derived_build_packs_by_default": {
          "type": "boolean"
        }
      }
    },
    "role_domain_template": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "template_id",
        "display_name",
        "summary",
        "selection_origin",
        "selection_reason",
        "catalog_path",
        "apply_to_derived_build_packs_by_default"
      ],
      "properties": {
        "template_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "selection_origin": {
          "type": "string",
          "enum": [
            "template_selected",
            "materialization_inherited_default",
            "materialization_selected"
          ]
        },
        "selection_reason": {
          "type": "string",
          "minLength": 1
        },
        "catalog_path": {
          "type": "string",
          "const": "docs/specs/project-pack-factory/agent-role-domain-template-catalog.json"
        },
        "apply_to_derived_build_packs_by_default": {
          "type": "boolean"
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "pack_kind": {
            "const": "template_pack"
          }
        }
      },
      "then": {
        "properties": {
          "post_bootstrap_read_order": {
            "type": "array",
            "minItems": 6,
            "prefixItems": [
              {
                "const": "status/lifecycle.json"
              },
              {
                "const": "status/readiness.json"
              },
              {
                "const": "status/retirement.json"
              },
              {
                "const": "status/deployment.json"
              },
              {
                "const": "benchmarks/active-set.json"
              },
              {
                "const": "eval/latest/index.json"
              }
            ],
            "items": false
          },
          "directory_contract": {
            "properties": {
              "project_objective_file": {
                "type": "null"
              },
              "tasks_dir": {
                "type": "null"
              },
              "task_backlog_file": {
                "type": "null"
              },
              "work_state_file": {
                "type": "null"
              },
              "lineage_dir": {
                "type": "null"
              },
              "lineage_file": {
                "type": "null"
              },
              "candidate_release_dir": {
                "type": "null"
              },
              "immutable_release_dir": {
                "type": "null"
              },
              "template_export_dir": {
                "const": "dist/exports"
              }
            }
          },
          "agent_native_project_profile": {
            "properties": {
              "activation_state": {
                "const": "template_declared"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "pack_kind": {
            "const": "build_pack"
          }
        }
      },
      "then": {
        "properties": {
          "post_bootstrap_read_order": {
            "anyOf": [
              {
                "type": "array",
                "minItems": 7,
                "prefixItems": [
                  {
                    "const": "status/lifecycle.json"
                  },
                  {
                    "const": "status/readiness.json"
                  },
                  {
                    "const": "status/retirement.json"
                  },
                  {
                    "const": "status/deployment.json"
                  },
                  {
                    "const": "lineage/source-template.json"
                  },
                  {
                    "const": "benchmarks/active-set.json"
                  },
                  {
                    "const": "eval/latest/index.json"
                  }
                ],
                "items": false
              },
              {
                "type": "array",
                "minItems": 10,
                "prefixItems": [
                  {
                    "const": "status/lifecycle.json"
                  },
                  {
                    "const": "status/readiness.json"
                  },
                  {
                    "const": "status/retirement.json"
                  },
                  {
                    "const": "status/deployment.json"
                  },
                  {
                    "const": "lineage/source-template.json"
                  },
                  {
                    "const": "contracts/project-objective.json"
                  },
                  {
                    "const": "tasks/active-backlog.json"
                  },
                  {
                    "const": "status/work-state.json"
                  },
                  {
                    "const": "benchmarks/active-set.json"
                  },
                  {
                    "const": "eval/latest/index.json"
                  }
                ],
                "items": false
              }
            ]
          },
          "directory_contract": {
            "properties": {
              "project_objective_file": {
                "const": "contracts/project-objective.json"
              },
              "tasks_dir": {
                "const": "tasks"
              },
              "task_backlog_file": {
                "const": "tasks/active-backlog.json"
              },
              "work_state_file": {
                "const": "status/work-state.json"
              },
              "lineage_dir": {
                "const": "lineage"
              },
              "lineage_file": {
                "const": "lineage/source-template.json"
              },
              "candidate_release_dir": {
                "const": "dist/candidates"
              },
              "immutable_release_dir": {
                "const": "dist/releases"
              },
              "template_export_dir": {
                "type": "null"
              }
            }
          },
          "agent_native_project_profile": {
            "properties": {
              "activation_state": {
                "const": "build_pack_active"
              }
            }
          }
        }
      }
    }
  ]
}
