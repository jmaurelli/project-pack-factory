{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/project-pack-factory/agent-role-domain-template-catalog.schema.json",
  "title": "Agent Role Domain Template Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "updated_at",
    "templates"
  ],
  "properties": {
    "schema_version": {
      "const": "agent-role-domain-template-catalog/v1"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "template_id",
          "display_name",
          "summary",
          "agent_context_lines",
          "project_context_lines"
        ],
        "properties": {
          "template_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "display_name": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "agent_context_lines": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "project_context_lines": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
