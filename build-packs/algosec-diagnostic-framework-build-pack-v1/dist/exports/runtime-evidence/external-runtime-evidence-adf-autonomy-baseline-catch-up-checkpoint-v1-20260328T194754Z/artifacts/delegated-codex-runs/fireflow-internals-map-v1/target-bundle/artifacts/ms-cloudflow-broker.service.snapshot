[Unit]
Description=ms-cloudflow-broker
Wants=network.target network-online.target httpd.service ms-configuration.service
After=network.target network-online.target httpd.service ms-configuration.service

[Service]
User=afa
LimitNOFILE=65535
WorkingDirectory=/home/afa
ExecStart=/usr/share/fa/mslib/ms-cloudflow-broker.jar
SuccessExitStatus=143
TimeoutStartSec=600
TimeoutStopSec=180

[Install]
WantedBy=multi-user.target
