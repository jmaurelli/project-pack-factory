<?php
require_once("RequireHeaders.php");
require_once("AlgosecSession.php");
header('Content-Type: application/json');
session_start();

// Impotant to release the lock from the session since there are no more session writes after this action
session_write_close();

$emptyAlgosecSession = empty($_SESSION['AlgosecSession']);
$machineSetup = getMachineSetup();
$isNoAuthUrl = isNoAuthUrl();
$fireflowAuth = utils::checkFireFlowAuth();

// NoAuth urls don't require any authentication
if($isNoAuthUrl)
{
    utils::PrintLog("Debug", "Allowing No Auth urls without validated session, URL=[".$_SERVER['HTTP_REFERER']."].");
}
else
{
    // Debug logs for each part of the condition
    utils::PrintLog("Info", "emptyAlgosecSession=[" . var_export($emptyAlgosecSession, true) . "]");
    utils::PrintLog("Info", "machineSetup['isAffEnabled']=[" . var_export($machineSetup['isAffEnabled'], true) . "]");
    utils::PrintLog("Info", "machineSetup['affVersionOK']=[" . var_export($machineSetup['affVersionOK'], true) . "]");
    utils::PrintLog("Info", "fireflowAuth=[" . var_export($fireflowAuth, true) . "]");
    utils::PrintLog("Info", "empty(fireflowAuth)=[" . (empty($fireflowAuth) ? 'true' : 'false') . "]");

    // The original condition
    if ($emptyAlgosecSession && (!$machineSetup['isAffEnabled'] || !$machineSetup['affVersionOK'] || empty($fireflowAuth))) {
        utils::PrintLog("Info", "Entering terminateWithError due to invalid session or configuration.");
        terminateWithError("Please log in");
    }

    // AFF enabled but AFF session is no longer valid - logout
    if (!$emptyAlgosecSession && 
        $machineSetup['isAffEnabled'] && 
        $machineSetup['affVersionOK'] && 
        empty($fireflowAuth)) {
        terminateWithError("Found sessions mismatch: valid AFA session and invliad AFF session, logging-out.");
    }
}

// Check if a license exists
$fa_lic_exists = file_exists('/var/opt/fa/fwa.lic');

$businessflow_installed = false;

$fireflow_configured = false;
$businessflow_show_setup_config_msg = false;

$businessflow_host = $_SERVER['HTTP_HOST'];

$config_file = "/home/afa/.fa/config";
if (file_exists($config_file)) {
    $regex = "/^FireFlow_configured=\s*yes\s*/";
    $arrResults = preg_grep($regex, file($config_file));
    if (count($arrResults) > 0) {
        $fireflow_configured = true;
    } else {
        $fireflow_configured = false;
    }

    // BusinessFlow
    $regex = "/^BUSINESSFLOW_ADDRESS=\s*(.+)\s*/";
    $arrResults = preg_grep($regex, file($config_file));
    $configLine = "";
    foreach ((array)$arrResults as $value) {
        $configLine = $value;
    }

    if (!empty($configLine)) {
        preg_match($regex, $configLine, $matches);

        $businessflow_installed = true;

        if (count($matches) > 1 && $matches[1] != "localhost") {
            $businessflow_host = $matches[1];
        }
    }

    $regex = "/^AlgoNext_License=\s*1\s*/";
    $arrResults = preg_grep($regex, file($config_file));
    if (count($arrResults) > 0) {
        $fa_lic_exists = true;
    }
}

$fireflow_installed = false;
if ($fireflow_configured) {
    $fireflow_installed = true;
} else {
    $affAddress = utils::GetFireFlowFullAddress();
    $sAffHealthCheckUrl = $affAddress . "/aff/api/internal/noauth/health/shallow";
    $fireflow_installed = utils::URLExists($sAffHealthCheckUrl);
}
$licenseExpire = utils::license();
$error = $licenseExpire == LICENSE_EXPIRE_GOOD ? NULL : utils::GetLicenseExpiresMessage($licenseExpire);
$licenseHasExpired = (isset($error) && $error != "");

$obj = array(
    "afa_licensed" => $fa_lic_exists,
    "afa_installed" => true,
    "afa_usable" => true,
    "afa_version_ok" => true,

    "aff_licensed" => $emptyAlgosecSession ? true : utils::is_fireflow_licensed(),
    "aff_installed" => $fireflow_installed,
    "aff_usable" => $fireflow_installed && $fireflow_configured && !empty($fireflowAuth),
    "aff_version_ok" => $machineSetup['affVersionOK'],

    "abf_licensed" => utils::is_businessflow_licensed(),
    "abf_installed" => $businessflow_installed,
    "abf_usable" => $businessflow_installed && !$businessflow_show_setup_config_msg,

    // If we are a requestor (PHP session is empty), don't useSession for license::expire
    "afa_license_about_to_expire" => utils::IsLicenseGoingToExpire(!$emptyAlgosecSession, $licenseExpire),
    "afa_license_has_expired" => $license_has_expired,
    "abf_host" => $businessflow_host,
    "requestor" => $emptyAlgosecSession // If we are authenticated (checked at the start) and emptyAlgosecSession, we are a requestor
);

header('Content-Type: application/json');
echo json_encode($obj);

// ===========================================================================

function getMachineSetup() {
    try {
        return RestClient::getMachineSetup();
    } catch (Exception $e) {
        utils::PrintLog("Fatal", "Failed to get machine setup: ". $e->getMessage());
        die("{}");
    }
}

function terminateWithError($errorMessage="Please log in")
{
    $obj = array("msg" => $errorMessage);

