# Security
management.security.enabled=false

# Kafka
kafka.queue.size=512
kafka.producer.poll.interval.ms=500
kafka.producer.health-check.interval.ms=3600000
kafka.producer.health-check.initial.interval.ms=120000

# Rest
httpclient.request.timeout.ms=3600000
httpclient.max.connections=120
asms.public.protocol=https
asms.public.url=localhost
asms.public.port=443
afa.auth.retry.initial.delay.ms=5000
afa.auth.retry.max.interval.ms=60000
afa.auth.retry.timeout.ms=300000
afa.auth.retry.multiplier=2

task.executor.max.thread.pool.size=80
