+{"cmd":"curl -sS -D /root/.pack-state/delegated-codex-runs/businessflow-aff-session-seam-validation-v1/artifacts/direct-aff-session.headers.txt http://localhost:1989/aff/api/external/session -o /root/.pack-state/delegated-codex-runs/businessflow-aff-session-seam-validation-v1/artifacts/direct-aff-session.body.json"}
+{"cmd":"systemctl status aff-boot.service --no-pager -l > /root/.pack-state/delegated-codex-runs/businessflow-aff-session-seam-validation-v1/artifacts/aff-boot.service.txt 2>&1 || true"}
+{"cmd":"cmp -s /root/.pack-state/delegated-codex-runs/businessflow-aff-session-seam-validation-v1/artifacts/apache-fireflow-session.body.json /root/.pack-state/delegated-codex-runs/businessflow-aff-session-seam-validation-v1/artifacts/direct-aff-session.body.json; echo $?"}
+{"cmd":"sha256sum /root/.pack-state/delegated-codex-runs/businessflow-aff-session-seam-validation-v1/artifacts/apache-fireflow-session.body.json /root/.pack-state/delegated-codex-runs/businessflow-aff-session-seam-validation-v1/artifacts/direct-aff-session.body.json"}
+{"cmd":"printf '=== HEADERS ===\\n' > /root/.pack-state/delegated-codex-runs/businessflow-aff-session-seam-validation-v1/artifacts/apache-fireflow-session.txt"}
+{"cmd":"cat /root/.pack-state/delegated-codex-runs/businessflow-aff-session-seam-validation-v1/artifacts/apache-fireflow-session.headers.txt >> /root/.pack-state/delegated-codex-runs/businessflow-aff-session-seam-validation-v1/artifacts/apache-fireflow-session.txt"}
