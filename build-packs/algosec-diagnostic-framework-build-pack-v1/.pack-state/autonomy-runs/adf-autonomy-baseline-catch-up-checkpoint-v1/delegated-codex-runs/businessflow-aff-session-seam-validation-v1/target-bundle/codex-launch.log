+{"cmd":"rg -n \"FireFlow/api/session|1989|aff/api/external/session|ProxyPass|aff-boot\" /etc/httpd/conf.d /usr/lib/systemd/system /usr/share/aff 2>/dev/null | head -n 200"}
+{"cmd":"sed -n '1,120p' /etc/httpd/conf.d/aff.conf"}
+{"cmd":"systemctl status aff-boot.service --no-pager -l || true"}
+{"cmd":"systemctl is-active aff-boot.service || true"}
+{"cmd":"sed -n '1,200p' /usr/lib/systemd/system/aff-boot.service"}
+{"cmd":"ls -la /usr/lib/systemd/system | grep aff-boot || true"}
+{"cmd":"curl -k -sS -D - https://localhost/FireFlow/api/session -o /tmp/apache_aff_session_body.txt | sed -n '1,40p'"}
+{"cmd":"sed -n '1,80p' /tmp/apache_aff_session_body.txt"}
+{"cmd":"curl -sS -D - http://localhost:1989/aff/api/external/session -o /tmp/direct_aff_session_body.txt | sed -n '1,40p'"}
+{"cmd":"sed -n '1,80p' /tmp/direct_aff_session_body.txt"}
+{"cmd":"cp /etc/httpd/conf.d/aff.conf /root/.pack-state/delegated-codex-runs/businessflow-aff-session-seam-validation-v1/artifacts/aff.conf.snapshot"}
