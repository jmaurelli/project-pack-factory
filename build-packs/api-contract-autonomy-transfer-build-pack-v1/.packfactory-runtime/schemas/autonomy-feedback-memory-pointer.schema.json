{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/project-pack-factory/autonomy-feedback-memory-pointer.schema.json",
  "title": "Autonomy Feedback Memory Pointer",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "updated_at",
    "pack_id",
    "selected_memory_id",
    "selected_run_id",
    "selected_generated_at",
    "selected_memory_path",
    "selected_memory_sha256",
    "source_kind",
    "source_import_id",
    "source_artifact_path",
    "source_import_report_path"
  ],
  "properties": {
    "schema_version": {
      "const": "autonomy-feedback-memory-pointer/v1"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "pack_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "selected_memory_id": {
      "type": "string",
      "minLength": 1
    },
    "selected_run_id": {
      "type": "string",
      "minLength": 1
    },
    "selected_generated_at": {
      "anyOf": [
        {
          "type": "string",
          "format": "date-time"
        },
        {
          "type": "null"
        }
      ]
    },
    "selected_memory_path": {
      "type": "string",
      "minLength": 1
    },
    "selected_memory_sha256": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "source_kind": {
      "type": "string",
      "enum": [
        "imported_external_runtime_evidence",
        "local_autonomy_run"
      ]
    },
    "source_import_id": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "source_artifact_path": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "source_import_report_path": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    }
  }
}
