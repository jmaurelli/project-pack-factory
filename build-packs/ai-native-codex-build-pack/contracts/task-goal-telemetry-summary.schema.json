{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task Goal Telemetry Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "producer",
    "summary_scope",
    "source_artifacts",
    "aggregate_counts",
    "result_breakdown",
    "stage_breakdown",
    "task_breakdown",
    "correlation_summary",
    "summary_notes"
  ],
  "properties": {
    "schema_version": {
      "const": "task-goal-telemetry-summary/v1"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "producer": {
      "type": "string",
      "minLength": 1
    },
    "summary_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_root",
        "telemetry_artifact_count"
      ],
      "properties": {
        "project_root": {
          "type": "string",
          "minLength": 1
        },
        "telemetry_artifact_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "source_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "task_name",
          "generated_at"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "task_name": {
            "type": "string",
            "minLength": 1
          },
          "generated_at": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "aggregate_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_attempts",
        "completed_count",
        "continue_working_count",
        "failed_count",
        "primary_goal_passed_count"
      ],
      "properties": {
        "total_attempts": {
          "type": "integer",
          "minimum": 1
        },
        "completed_count": {
          "type": "integer",
          "minimum": 0
        },
        "continue_working_count": {
          "type": "integer",
          "minimum": 0
        },
        "failed_count": {
          "type": "integer",
          "minimum": 0
        },
        "primary_goal_passed_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "result_breakdown": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "stage_breakdown": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_goal_gate",
        "broader_validation",
        "none"
      ],
      "properties": {
        "primary_goal_gate": {
          "type": "integer",
          "minimum": 0
        },
        "broader_validation": {
          "type": "integer",
          "minimum": 0
        },
        "none": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "task_breakdown": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "task_name",
          "attempt_count",
          "completed_count",
          "continue_working_count",
          "failed_count",
          "primary_goal_passed_count"
        ],
        "properties": {
          "task_name": {
            "type": "string",
            "minLength": 1
          },
          "attempt_count": {
            "type": "integer",
            "minimum": 1
          },
          "completed_count": {
            "type": "integer",
            "minimum": 0
          },
          "continue_working_count": {
            "type": "integer",
            "minimum": 0
          },
          "failed_count": {
            "type": "integer",
            "minimum": 0
          },
          "primary_goal_passed_count": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "correlation_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_ids",
        "build_run_manifest_paths"
      ],
      "properties": {
        "run_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "build_run_manifest_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "summary_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
