{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Predispatch Decision Contract",
  "description": "Canonical JSON Schema for persisted pre-dispatch gate decisions only. This contract defines a machine-readable gate-decision artifact for dispatch authorization, blocking, or escalation outcomes. It intentionally excludes worker-result payloads, full task-record payloads, approval-policy definitions, and runtime implementation logic.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "decision",
    "resulting_task_state",
    "task_record_reference",
    "delegation_brief_reference",
    "approval_state",
    "validator_results",
    "persisted_artifacts"
  ],
  "properties": {
    "task_id": {
      "$ref": "#/$defs/task_id",
      "description": "Stable task identifier for the candidate dispatch attempt."
    },
    "decision": {
      "type": "string",
      "enum": [
        "dispatch",
        "blocked",
        "escalate"
      ],
      "description": "Canonical pre-dispatch gate outcome only."
    },
    "resulting_task_state": {
      "type": "string",
      "enum": [
        "ready_to_dispatch",
        "blocked",
        "escalated"
      ],
      "description": "Explicit orchestrator task state produced by the pre-dispatch decision contract."
    },
    "task_record_reference": {
      "$ref": "#/$defs/task_record_reference",
      "description": "Exact task-record artifact evaluated by the pre-dispatch gate."
    },
    "delegation_brief_reference": {
      "$ref": "#/$defs/delegation_brief_reference",
      "description": "Exact delegation-brief artifact evaluated by the pre-dispatch gate."
    },
    "approval_state": {
      "$ref": "./approval-state.schema.json",
      "description": "Approval-state value used by the pre-dispatch decision. The value shape is defined by the dedicated approval-state contract."
    },
    "validator_results": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/predispatch_validator_result"
      },
      "description": "Structured validator outcomes used to compute the pre-dispatch gate decision."
    },
    "persisted_artifacts": {
      "$ref": "#/$defs/predispatch_persisted_artifacts",
      "description": "Persisted audit and replay references for the pre-dispatch decision artifact."
    },
    "blocking_reasons": {
      "$ref": "#/$defs/non_empty_string_array",
      "description": "Ordered non-empty blocking reasons present only when the decision is blocked."
    },
    "escalation_reason": {
      "$ref": "#/$defs/non_empty_string",
      "description": "Escalation reason present only when the decision is escalate."
    },
    "dispatch_attempt": {
      "type": "integer",
      "minimum": 1,
      "description": "1-based dispatch-attempt counter for this task."
    },
    "emitted_at": {
      "type": "string",
      "format": "date-time",
      "description": "UTC timestamp for when the pre-dispatch decision artifact was emitted."
    }
  },
  "allOf": [
    {
      "properties": {
        "validator_results": {
          "contains": {
            "type": "object",
            "properties": {
              "validator_name": {
                "const": "validate-task-brief"
              }
            },
            "required": [
              "validator_name"
            ]
          }
        }
      }
    },
    {
      "properties": {
        "validator_results": {
          "contains": {
            "type": "object",
            "properties": {
              "validator_name": {
                "const": "validate-task-order-and-approval"
              }
            },
            "required": [
              "validator_name"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision": {
            "const": "dispatch"
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "properties": {
          "resulting_task_state": {
            "const": "ready_to_dispatch"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision": {
            "const": "blocked"
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "properties": {
          "resulting_task_state": {
            "const": "blocked"
          }
        },
        "required": [
          "blocking_reasons"
        ]
      },
      "else": {
        "not": {
          "required": [
            "blocking_reasons"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision": {
            "const": "escalate"
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "properties": {
          "resulting_task_state": {
            "const": "escalated"
          }
        },
        "required": [
          "escalation_reason"
        ]
      },
      "else": {
        "not": {
          "required": [
            "escalation_reason"
          ]
        }
      }
    }
  ],
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1,
      "pattern": ".*\\S.*"
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "task_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9]+(?:[._-][A-Za-z0-9]+)*$",
      "description": "Lexical task identifier used for deterministic task selection and artifact correlation."
    },
    "artifact_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_role",
        "reference",
        "content_digest"
      ],
      "properties": {
        "artifact_role": {
          "$ref": "#/$defs/non_empty_string",
          "description": "Stable role label for the referenced artifact."
        },
        "reference": {
          "$ref": "#/$defs/non_empty_string",
          "description": "Stable path, URI, or bundle-local identifier for the exact artifact."
        },
        "content_digest": {
          "$ref": "#/$defs/non_empty_string",
          "description": "Stable content digest or equivalent immutable identity for replay."
        }
      }
    },
    "task_record_reference": {
      "allOf": [
        {
          "$ref": "#/$defs/artifact_reference"
        },
        {
          "properties": {
            "artifact_role": {
              "const": "task_record"
            }
          }
        }
      ]
    },
    "delegation_brief_reference": {
      "allOf": [
        {
          "$ref": "#/$defs/artifact_reference"
        },
        {
          "properties": {
            "artifact_role": {
              "const": "delegation_brief"
            }
          }
        }
      ]
    },
    "validator_result_reference": {
      "allOf": [
        {
          "$ref": "#/$defs/artifact_reference"
        },
        {
          "properties": {
            "artifact_role": {
              "const": "validator_result"
            }
          }
        }
      ]
    },
    "decision_artifact_reference": {
      "allOf": [
        {
          "$ref": "#/$defs/artifact_reference"
        },
        {
          "properties": {
            "artifact_role": {
              "const": "predispatch_decision"
            }
          }
        }
      ]
    },
    "approval_policy_reference": {
      "allOf": [
        {
          "$ref": "#/$defs/artifact_reference"
        },
        {
          "properties": {
            "artifact_role": {
              "const": "approval_policy"
            }
          }
        }
      ]
    },
    "predispatch_validator_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validator_name",
        "outcome",
        "result_reference",
        "summary"
      ],
      "properties": {
        "validator_name": {
          "type": "string",
          "enum": [
            "validate-task-brief",
            "validate-task-order-and-approval"
          ],
          "description": "Canonical validator name contributing to the pre-dispatch decision."
        },
        "outcome": {
          "type": "string",
          "enum": [
            "pass",
            "warn",
            "fail",
            "blocked"
          ],
          "description": "Structured validator outcome used by the gate decision."
        },
        "result_reference": {
          "$ref": "#/$defs/validator_result_reference",
          "description": "Exact validator-result artifact used as decision evidence."
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string",
          "description": "Concise machine-readable summary of the validator outcome."
        }
      }
    },
    "predispatch_persisted_artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_artifact_reference",
        "approval_policy_reference",
        "validator_result_references",
        "input_artifacts"
      ],
      "properties": {
        "decision_artifact_reference": {
          "$ref": "#/$defs/decision_artifact_reference",
          "description": "Reference for the persisted pre-dispatch decision artifact itself."
        },
        "approval_policy_reference": {
          "$ref": "#/$defs/approval_policy_reference",
          "description": "Exact approval-policy artifact version used when computing dispatchability."
        },
        "validator_result_references": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/validator_result_reference"
          },
          "description": "Exact persisted validator-result artifacts used to derive the gate decision."
        },
        "input_artifacts": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/artifact_reference"
          },
          "description": "Stable references and digests for the persisted input artifacts required to replay the decision."
        }
      },
      "allOf": [
        {
          "properties": {
            "input_artifacts": {
              "contains": {
                "type": "object",
                "properties": {
                  "artifact_role": {
                    "const": "task_record"
                  }
                },
                "required": [
                  "artifact_role"
                ]
              }
            }
          }
        },
        {
          "properties": {
            "input_artifacts": {
              "contains": {
                "type": "object",
                "properties": {
                  "artifact_role": {
                    "const": "delegation_brief"
                  }
                },
                "required": [
                  "artifact_role"
                ]
              }
            }
          }
        }
      ]
    }
  }
}
