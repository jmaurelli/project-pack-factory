{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/project-pack-factory/deployment-pointer.schema.json",
  "title": "Environment Deployment Pointer",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "environment",
    "pack_id",
    "pack_kind",
    "pack_root",
    "source_deployment_file",
    "active_release_id",
    "active_release_path",
    "deployment_transaction_id",
    "promotion_evidence_ref",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "pack-deployment-pointer/v2"
    },
    "environment": {
      "type": "string",
      "enum": [
        "testing",
        "staging",
        "production"
      ]
    },
    "pack_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "pack_kind": {
      "type": "string",
      "const": "build_pack"
    },
    "pack_root": {
      "type": "string",
      "pattern": "^build-packs/[a-z0-9][a-z0-9_-]*$"
    },
    "source_deployment_file": {
      "type": "string",
      "pattern": "^build-packs/[a-z0-9][a-z0-9_-]*/status/deployment\\.json$"
    },
    "active_release_id": {
      "type": "string",
      "minLength": 1
    },
    "active_release_path": {
      "type": "string",
      "pattern": "^dist/releases/[^/]+$"
    },
    "deployment_transaction_id": {
      "type": "string",
      "minLength": 1
    },
    "promotion_evidence_ref": {
      "type": "string",
      "pattern": "^(eval/.+|orchestration/.+)$"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
